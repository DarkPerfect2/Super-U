# Backend (Render) - Production
NODE_ENV=production
PORT=5000
SERVE_CLIENT=false

# Logs
LOG_LEVEL=warn
# Token refresh policy
REFRESH_TOKEN_EXPIRY=7d

# Security
JWT_SECRET=REPLACE_ME_WITH_A_STRONG_SECRET

# Database (MongoDB Atlas)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=giantcasino

# CORS / Frontends
# Remplacez par vos domaines finaux (boutique et admin)
FRONTEND_URL=https://super-u.your-domain.tld
CORS_ALLOWED_ORIGINS=https://super-u.your-domain.tld,https://admin.your-domain.tld
# COOKIE_DOMAIN=.your-domain.tld

# Email (facultatif)
GMAIL_USER=
GMAIL_APP_PASSWORD=

# SMS.to (facultatif)
SMS_TO_API_KEY=

# Cloudinary (facultatif)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
